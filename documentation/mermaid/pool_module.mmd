flowchart TD
    Start([PoolModule::Allocate]) --> LoadTLS[Load TLS ActiveSlab]
    
    LoadTLS --> CheckActive{ActiveSlab has free slot?}
    CheckActive -- Yes (Fast Path) --> PopSlot[Pop from TLS m_FreeListHead]
    
    CheckActive -- No --> CheckCursor{FirstNonFullSlab valid?}
    
    subgraph "Thread-Local Chain Scan"
        CheckCursor -- Valid --> StartScan[Scan from FirstNonFullSlab]
        CheckCursor -- Null --> ScanHead[Scan from HeadSlab]
        
        StartScan --> SlabCheck{Space Available?}
        ScanHead --> SlabCheck
        
        SlabCheck -- No (Full) --> MoveNext[Iterate NextSlab] --> ChainEnd{End of Chain?}
        ChainEnd -- No --> SlabCheck
        ChainEnd -- Yes --> SlowPath[GrowSlabChain]
    end
    
    SlabCheck -- Yes --> UpdateState[ActiveSlab = Current] --> PopSlot
    
    subgraph "Batched Registry Fetch (Slow Path)"
        SlowPath --> Lock[Acquire g_ContextMutex]
        Lock --> Batch[Registry->AllocateSlabBatch]
        Batch --> Link[Append N Slabs to TLS Chain]
        Link --> Unlock[Release g_ContextMutex] --> PopSlot
    end
    
    PopSlot --> RetPtr([Return void*])

    subgraph "Global Deallocation (PoolStrategy::Free)"
        StartFree([FreeHandle]) --> ExtractBucket[Resolve to Bucket Scope]
        ExtractBucket --> LoadCAS[Load atomic GlobalFreeList]
        LoadCAS --> CASLoop{atomic_compare_exchange_weak}
        CASLoop -- Fail (ABA Contention) --> CASLoop
        CASLoop -- Success --> EndFree([Memory Reclaimed])
    end
