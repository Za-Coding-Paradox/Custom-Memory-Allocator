flowchart TD
    %% Node Definitions
    App("🎮 User Game Loop / Simulation\n(Requesting 2,000 mixed frames)")
    Engine("⚙️ AllocatorEngine\n(>16MB Heap Object)")
    
    subgraph "🗄️ Thread-Local Storage (Fast Path)"
        LinTLS("LinearModule TLS\n[alignas 64]\nActiveSlab | BumpCursor")
        PoolTLS("PoolModule TLS\n[alignas 64]\nActiveSlab | FirstNonFull")
        ShardCache("Handle ShardCache\n[alignas 64]\nhash(thread_id) % 32")
    end
    
    subgraph "🔐 Global Process Memory (Slow Path)"
        Registry("SlabRegistry\n(Manages 512MB Arena)")
        Bitmap("Two-Level Atomic Bitmap\n(m_SuperBlock -> m_BitMap)")
        HTable("HandleTable\n(32 Mutex-Guarded Shards)")
        HMetadata("HandleMetadata Array\n(Generational Seqlocks)")
    end
    
    subgraph "🐧 Linux OS & Hardware"
        Syscall("sys/mman.h\n(mmap, MAP_ANONYMOUS)")
        RAM("Physical Memory Pages")
    end

    %% Application flow
    App == "1. Allocate<FrameLoad>()\n[Cost: 4.93 ns/op]" ===> Engine
    App == "2. AllocateWithHandle<RigidBody>()\n[Cost: 26.25 ns/op]" ===> Engine
    
    %% Engine routes to TLS
    Engine -. "if constexpr (IsPool == false)" .-> LinTLS
    Engine -. "if constexpr (IsPool == true)" .-> PoolTLS
    
    %% TLS interacts with Global
    LinTLS -- "BumpCursor Exhausted\n[GrowSlabChain]" --> Registry
    PoolTLS -- "Slab Chain Exhausted\n[GrowSlabChain]" --> Registry
    PoolTLS -- "Generates Pointer" --> ShardCache
    
    ShardCache -- "Indexes specific Shard" --> HTable
    HTable -- "CAS Pointer & Incr Gen" --> HMetadata
    
    %% Global interacts with OS
    Registry -- "Amortized O(1) Search" --> Bitmap
    Registry == "Initialize() called once" ===> Syscall
    Syscall -- "Pre-faults via memset\neliminating lazy zeroing" --> RAM

    %% Styles
    classDef boundary fill:transparent,stroke:#bdc3c7,stroke-width:2px,stroke-dasharray: 5 5
    class "🗄️ Thread-Local Storage (Fast Path)" boundary
    class "🔐 Global Process Memory (Slow Path)" boundary
    class "🐧 Linux OS & Hardware" boundary
