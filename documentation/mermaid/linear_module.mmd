stateDiagram-v2
    state "Thread Local Storage (alignas 64)" as TLS {
        HeadSlab
        ActiveSlab
        BumpCursor
        Stats(Alloc/Bytes)
        char_Padding[64_Byte_Enforcement]
    }

    [*] --> Idle

    state "Allocation Phase" as Alloc {
        Idle --> CheckFit : Allocate(Size, Align)
        
        state fit_check <<choice>>
        CheckFit --> fit_check : (BumpCursor + Size) < ActiveSlab.End ?
        
        fit_check --> FastPath : Yes (Fits in Slab)
        fit_check --> SlowPath : No (Overflows)
        
        FastPath --> BumpPointer : Advance BumpCursor
        BumpPointer --> ReturnPtr : Cost ~4.93 ns/op
        
        state "OverFlowAllocate() Trigger" as SlowPath {
            CheckNext : Read ActiveSlab->NextSlab
            
            state next_branch <<choice>>
            CheckNext --> next_branch
            
            next_branch --> Reuse : NextSlab != nullptr
            next_branch --> Grow : NextSlab == nullptr
            
            state "Reuse Pre-Allocated Chain" as Reuse {
                AdvanceActive : ActiveSlab = NextSlab
                ResetCursor : BumpCursor = ActiveSlab.Start
            }
            
            state "Grow Slab Chain" as Grow {
                LockReg : Acquire g_ContextMutex
                ReqReg : Registry->AllocateSlab()
                UnlockReg : Release g_ContextMutex
                Attach : ActiveSlab->Next = NewSlab
                AdvanceNew : ActiveSlab = NewSlab
            }
        }
    }

    state "O(1) Rewind Phase" as Reset {
        UserReset --> ResetHeads
        ResetHeads --> RebindActive : ActiveSlab = HeadSlab
        RebindActive --> RebindCursor : BumpCursor = HeadSlab.Start
        RebindCursor --> Idle : Chain kept alive in memory
    }
