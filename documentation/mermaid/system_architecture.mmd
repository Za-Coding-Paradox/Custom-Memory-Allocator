graph TD
    subgraph "User Application Layer"
        App[Game Simulation / Application]
        App -->|1. Allocate<FrameLoad>| Facade
        App -->|2. AllocateWithHandle<RigidBody>| Facade
        App -->|3. Reset<FrameLoad>| Facade
    end

    subgraph "Facade Layer"
        Facade[AllocatorEngine]
        Traits[ScopeTraits C++20 Requires]
        Facade -.->|Compile-Time Branching| Traits
    end

    subgraph "Strategy Layer (Isolated Threads)"
        direction TB
        
        subgraph "Linear (Bump Pointer)"
            LinMod[LinearStrategyModule<TScope>]
            LinTLS[alignas 64 ThreadLocalData]
            LinMod -- Zero-Contention Access --> LinTLS
        end
        
        subgraph "Pool (Fixed Size Buckets)"
            PoolMod[PoolModule<BucketScope<N>>]
            PoolTLS[alignas 64 ThreadLocalData]
            PoolMod -- Fast Path Access --> PoolTLS
            
            PoolCAS[Global atomic void* CAS Freelist]
            PoolMod -- Slow Path Free --> PoolCAS
        end
    end

    subgraph "Handle System (Safety)"
        HT[HandleTable]
        Shards[32x HandleTableShard]
        HT -- Hashed by Thread ID --> Shards
        Shards -- Seqlock Generation Array --> Meta[HandleMetadata]
    end

    subgraph "Physical Layer (Linux OS Environment)"
        Reg[SlabRegistry]
        Super[atomic m_SuperBlock Two-Level Bitmap]
        Arena[512MB Contiguous pre-faulted mmap Arena]
        
        Reg -- O(1) PopCnt Scan --> Super
        Reg -- Partitions 64KB Slabs --> Arena
    end

    %% Edge Links
    Facade -->|Traits Route| LinMod
    Facade -->|Traits Route| PoolMod
    Facade -->|Pool Wraps| HT
    
    LinMod -->|SlowPath Batch Fetch| Reg
    PoolMod -->|SlowPath Batch Fetch| Reg
    
    HT -.->|Resolves Ptr| Arena
