flowchart TD
    Start([User Calls Allocate / AllocateWithHandle]) --> Traits{ScopeTraits<TScope>}
    
    subgraph "Compile-Time Branching (Zero Runtime Cost)"
        Traits -- "IsPool == false\nSupportsHandles == false" --> LinearPath
        Traits -- "IsPool == true\nSupportsHandles == true" --> PoolPath
    end

    subgraph "Linear Path (Fast Bump)"
        LinearPath[RawAllocateInternal<TScope>]
        LinearPath --> CallLinear[LinearStrategyModule::Allocate]
        CallLinear --> LinearReturn([Return void* Raw Pointer])
    end

    subgraph "Pool Path (Thread-Local Cache + Handles)"
        PoolPath[RawAllocateInternal<PoolScope<T>>]
        PoolPath --> ResolveBucket[PoolMap resolves to BucketScope<N>]
        ResolveBucket --> CallPool[PoolModule<BucketScope<N>>::Allocate]
        
        CallPool --> CheckPoolResult{Memory Valid?}
        CheckPoolResult -- No (OOM) --> RetInvalid([Return g_InvalidHandle])
        CheckPoolResult -- Yes --> CreateHandle[HandleTable::Allocate]
        
        CreateHandle --> HT_ShardHash[Hash Thread ID % 32]
        HT_ShardHash --> HT_AllocateRaw[Shard::AllocateRaw]
        HT_AllocateRaw --> PoolReturn([Return 64-bit Packed Handle])
    end
    
    subgraph "Seqlock Resolve Path"
        UserResolve([User Calls ResolveHandle]) --> DecodeBits[Decode 5-bit Shard, 27-bit Index]
        DecodeBits --> CheckSeqLock{Handle.Gen == Metadata.Gen?}
        CheckSeqLock -- No (Stale/Odd) --> RetNull([Return nullptr])
        CheckSeqLock -- Yes --> RetPtr([Return Cast T*])
    end
