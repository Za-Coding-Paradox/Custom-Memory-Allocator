---
# Enable checks for:
# - Bugprone: Common bugs
# - Modernize: C++20/17 features
# - Performance: Efficiency checks
# - Readability: Naming conventions
# - Clang-Analyzer: Deep static analysis
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  modernize-*,
  performance-*,
  readability-*,
  misc-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -llvmlibc-*

# Regex to ensure it checks your source files but ignores system libs
HeaderFilterRegex: 'src/.*|include/.*'

# ----------------------------------------------------------------------------
# CHECK OPTIONS
# ----------------------------------------------------------------------------
# NOTE: Modern syntax uses "Key: Value" directly, not "- key: X, value: Y"
CheckOptions:
  # --------------------------------------------------------------------------
  # FUNCTION & VARIABLE NAMING (CamelCase)
  # --------------------------------------------------------------------------
  readability-identifier-naming.FunctionCase: CamelCase
  readability-identifier-naming.LocalVariableCase: CamelCase
  readability-identifier-naming.ParameterCase: CamelCase

  # --------------------------------------------------------------------------
  # CLASS MEMBER NAMING
  # --------------------------------------------------------------------------
  # Private Members: m_CamelCase
  readability-identifier-naming.PrivateMemberCase: CamelCase
  readability-identifier-naming.PrivateMemberPrefix: m_

  # Public Members: p_CamelCase
  readability-identifier-naming.PublicMemberCase: CamelCase
  readability-identifier-naming.PublicMemberPrefix: p_

  # Protected Members: m_CamelCase
  readability-identifier-naming.ProtectedMemberCase: CamelCase
  readability-identifier-naming.ProtectedMemberPrefix: m_

  # --------------------------------------------------------------------------
  # GLOBALS, STATICS, CONSTANTS (g_CamelCase)
  # --------------------------------------------------------------------------
  # Global Variables
  readability-identifier-naming.GlobalVariableCase: CamelCase
  readability-identifier-naming.GlobalVariablePrefix: g_

  # Static Variables
  readability-identifier-naming.StaticVariableCase: CamelCase
  readability-identifier-naming.StaticVariablePrefix: g_

  # Global Constants
  readability-identifier-naming.GlobalConstantCase: CamelCase
  readability-identifier-naming.GlobalConstantPrefix: g_

  # --------------------------------------------------------------------------
  # TYPES
  # --------------------------------------------------------------------------
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.StructCase: CamelCase
  readability-identifier-naming.TemplateParameterCase: CamelCase

  # --------------------------------------------------------------------------
  # MISC SETTINGS
  # --------------------------------------------------------------------------
  # Cognitive Complexity
  readability-function-cognitive-complexity.Threshold: 25

  # Magic Numbers (Ignore 0 and 1)
  readability-magic-numbers.IgnoredIntegerValues: '0;1'
